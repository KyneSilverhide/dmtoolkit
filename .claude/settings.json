{
  "permissions": {
    "allow": [
      "Bash(node --check*)",
      "Bash(npm test)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run preview)",
      "Bash(npm install)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git stash list)",
      "Bash(git pull)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(ls*)",
      "Bash(dir*)",
      "Bash(Get-ChildItem*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NonInteractive -File .claude/hooks/check-docs.ps1"
          }
        ]
      }
    ]
  }
}
